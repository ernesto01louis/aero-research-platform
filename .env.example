# Copy to `.env` and edit. `.env` is gitignored.
#
# Base URL of the AI Orchestrator REST API.
# Default 127.0.0.1:8000 assumes you're running on the same LXC as the
# orchestrator (LXC 200). From a workstation use the orchestrator's LAN
# address — e.g. http://192.168.2.218:8000 — or the tailnet name.
ORCHESTRATOR_URL=http://127.0.0.1:8000

# Phase 1.7 bearer-token auth. Leave blank if the orchestrator's
# ORCHESTRATOR_API_TOKEN is unset (auth is opt-in).
ORCHESTRATOR_TOKEN=
