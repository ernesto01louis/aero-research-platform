# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Build
build/
dist/
wheels/
*.whl

# Virtual environments
.venv/
venv/
env/
.python-version

# uv lockfile is checked in for reproducibility
# (do not exclude uv.lock)

# Local secrets
.env
.env.local
*.pem
*.key

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Bulk data — keep .gitkeep stubs only
data/*
!data/.gitkeep
# Small reference datasets (digitized literature curves) are calibration
# inputs, not bulk artifacts — commit them so the notebook is reproducible.
!data/bechert-1997-fig5/
!data/bechert-1997-fig5/**
results/*
!results/.gitkeep
# Per-campaign run logs are small (campaign_id + flow_run_id pointers)
# and worth committing as evidence the campaign was launched. Real
# CFD artifacts (postProcessing, VTK, polyMesh) stay out.
!results/**/run-log.json

# DVC (if/when activated; mirrors orchestrator .gitignore pattern)
/dvc-cache/
