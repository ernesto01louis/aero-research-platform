# Rendered by the Vault Agent — secrets from Vault KV v2 at aero/.
{{- with secret "aero/data/postgres/aero_mlflow_user" }}
MLFLOW_BACKEND_STORE_URI=postgresql://aero_mlflow_user:{{ .Data.data.password }}@192.168.2.184:5432/aero_mlflow
{{- end }}
{{- with secret "aero/data/minio/mlflow-sa" }}
AWS_ACCESS_KEY_ID={{ .Data.data.access_key }}
AWS_SECRET_ACCESS_KEY={{ .Data.data.secret_key }}
{{- end }}
MLFLOW_S3_ENDPOINT_URL=http://aero-mlflow:9000
