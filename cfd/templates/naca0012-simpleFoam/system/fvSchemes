FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

ddtSchemes
{
    default         steadyState;
}

gradSchemes
{
    default         Gauss linear;
    // Stage-4.x α=10 fix: cellLimited Gauss linear 1 (the hard clamp)
    // suppressed the bound-vortex sheet that sets the Kutta condition
    // at incidence — simpleFoam settled to a low-circulation steady
    // state (Cl=0.09 instead of NASA TMR 1.09). cellMDLimited with
    // limiter strength 0.5 is multi-directional and softer; still
    // stable on the 7.7k degenerate cells from snappyHexMesh addLayers
    // but lets the gradient develop the lift.
    grad(U)         cellMDLimited Gauss linear 0.5;
    grad(p)         cellLimited Gauss linear 1;
}

divSchemes
{
    default         none;
    // Stage-4.x tuning: SA's near-wall production was the culprit
    // when degenerate cells were present. First-order `upwind` on
    // nuTilda is strictly bounded; sacrifices accuracy for stability.
    div(phi,U)      bounded Gauss linearUpwindV grad(U);
    div(phi,nuTilda) bounded Gauss upwind;
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    // Stage-4.x: switched from meshWave to Poisson. meshWave on cells
    // with very small determinant returns near-zero wall distance,
    // which makes SA's destruction term pow3(nuTilda/d^3) overflow to
    // FPE. Poisson is more robust on degenerate cells.
    method          Poisson;
}
