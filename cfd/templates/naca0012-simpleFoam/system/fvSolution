FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration on;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel 100;
        mergeLevels     1;
    }

    U
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.1;
        nSweeps         2;
    }

    nuTilda
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.1;
        nSweeps         2;
    }

    // y-field is the Poisson wall-distance variable (fvSchemes wallDist.method=Poisson).
    // meshWave was producing near-zero d in degenerate prism cells, which
    // overflowed SA's pow3(nuTilda/d^3) destruction term to FPE.
    yPsi
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.0;
    }

    // Velocity potential for potentialFoam initialization (Stage-4.x
    // α=10 cold-start fix per STAGE-4-OUTPUTS Issue 4 priority-1). Without
    // this entry potentialFoam -writephi exits with "Entry 'Phi' not
    // found in dictionary system/fvSolution/solvers" and the run cold-
    // starts simpleFoam without the bound-circulation seed → Cl trap.
    Phi
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration on;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel 100;
        mergeLevels     1;
    }
}

// potentialFoam-specific solver controls. potentialFoam reads
// potentialFlow{} (or falls back to defaults). Explicit block avoids
// surprises across OpenFOAM versions.
potentialFlow
{
    nNonOrthogonalCorrectors 5;
}

SIMPLE
{
    nNonOrthogonalCorrectors 0;
    consistent      yes;
    residualControl
    {
        p           1e-6;
        U           1e-6;
        nuTilda     1e-6;
    }
}

relaxationFactors
{
    fields
    {
        p           0.7;
    }
    equations
    {
        U           0.7;
        nuTilda     0.7;
    }
}

cache
{
    grad(U);
}
