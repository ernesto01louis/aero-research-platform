FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    xMinCyclic
    {
        type            cyclic;
    }
    xMaxCyclic
    {
        type            cyclic;
    }
    top
    {
        type            symmetryPlane;
    }
    "(bottomWall|riblets)"
    {
        // nutLowReWallFunction returns 0 at the wall for wall-resolved
        // y+ < 1 meshes — correct for the periodic-channel mesh
        // (y+ ~ 0.2-0.5 on the riblet + groove walls).
        type            nutLowReWallFunction;
        value           uniform 0;
    }
    frontPeriodic
    {
        type            cyclic;
    }
    backPeriodic
    {
        type            cyclic;
    }
}
