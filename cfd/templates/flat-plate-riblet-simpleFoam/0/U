FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

// Streamwise-periodic channel, normalized on u_tau=1. Initial guess at
// the bulk velocity (~15 u_tau for a Re_tau=180 channel); the
// meanVelocityForce in constant/fvOptions drives it to the target.
internalField   uniform (15 0 0);

boundaryField
{
    xMinCyclic
    {
        type            cyclic;
    }
    xMaxCyclic
    {
        type            cyclic;
    }
    top
    {
        type            symmetryPlane;
    }
    // Riblet case has both `bottomWall` (groove floors) and `riblets`
    // (blade walls + tips). Smooth case has only `bottomWall`. Regex
    // matches whichever exist.
    "(bottomWall|riblets)"
    {
        type            noSlip;
    }
    frontPeriodic
    {
        type            cyclic;
    }
    backPeriodic
    {
        type            cyclic;
    }
}
