FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

// Specific dissipation rate. For a Re_tau=180 channel (u_tau=1,
// delta=1) omega ~ O(10-100) through most of the channel; a uniform
// 10 initial guess relaxes fine. omegaWallFunction sets the very large
// near-wall value automatically.
dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 10;

boundaryField
{
    xMinCyclic
    {
        type            cyclic;
    }
    xMaxCyclic
    {
        type            cyclic;
    }
    top
    {
        type            symmetryPlane;
    }
    "(bottomWall|riblets)"
    {
        // omegaWallFunction handles both wall-resolved (y+<1) and
        // wall-function (y+>30) regimes via Menter's blending.
        type            omegaWallFunction;
        value           uniform 10;
    }
    frontPeriodic
    {
        type            cyclic;
    }
    backPeriodic
    {
        type            cyclic;
    }
}
