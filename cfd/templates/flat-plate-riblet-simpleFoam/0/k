FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

// Turbulent kinetic energy, normalized on u_tau=1. A Re_tau=180 channel
// has k ~ O(1-4) u_tau^2; a uniform 1.0 initial guess relaxes fine.
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1.0;

boundaryField
{
    xMinCyclic
    {
        type            cyclic;
    }
    xMaxCyclic
    {
        type            cyclic;
    }
    top
    {
        type            symmetryPlane;
    }
    "(bottomWall|riblets)"
    {
        type            kLowReWallFunction;
        value           uniform 1e-10;
    }
    frontPeriodic
    {
        type            cyclic;
    }
    backPeriodic
    {
        type            cyclic;
    }
}
