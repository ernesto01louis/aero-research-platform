FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

// Freestream turbulent kinetic energy. With U_infty=1 (non-dim) and
// turbulence intensity Tu = 0.1% (canonical low-disturbance wind tunnel
// — matches NASA TMR flat-plate ZPG references), k_infty = 1.5*(Tu*U)^2
// = 1.5e-6. Small but nonzero so kOmegaSST has something to transport.
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1.5e-6;

boundaryField
{
    inlet
    {
        type            freestream;
        freestreamValue uniform 1.5e-6;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 1.5e-6;
        value           uniform 1.5e-6;
    }
    top
    {
        type            slip;
    }
    bottomWall
    {
        type            kLowReWallFunction;
        value           uniform 1e-10;
    }
    frontPeriodic
    {
        type            cyclic;
    }
    backPeriodic
    {
        type            cyclic;
    }
}
