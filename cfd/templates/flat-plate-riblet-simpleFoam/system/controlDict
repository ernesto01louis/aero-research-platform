FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     simpleFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         10000;
deltaT          1;
writeControl    timeStep;
writeInterval   1000;
purgeWrite      2;
writeFormat     ascii;
writePrecision  10;
writeCompression off;
timeFormat      general;
timePrecision   8;
runTimeModifiable yes;

functions
{
    // Drag-extraction strategy: integrate wall shear stress over the
    // bottomWall patch in the converged tail. forceCoeffs is airfoil-
    // specific (CofR, lift/drag axes) and the wrong tool for ZPG flat
    // plate. The notebook in notebooks/02-bechert-1997-replication.ipynb
    // pulls postProcessing/wallShearStress/0/wallShearStress.dat, averages
    // over the last 2000 iterations, and integrates over the measurement
    // window (set in FlatPlateRibletMeshSpec.meas_window_x_start..end).
    wallShearStress
    {
        type            wallShearStress;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   10;
        patches         ( bottomWall );
        log             yes;
    }

    residuals
    {
        type            residuals;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields          ( U p k omega );
    }

    yPlus
    {
        type            yPlus;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        patches         ( bottomWall );
    }
}
