FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     simpleFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         6000;
deltaT          1;
writeControl    timeStep;
writeInterval   1000;
purgeWrite      2;
writeFormat     ascii;
writePrecision  10;
writeCompression off;
timeFormat      general;
timePrecision   8;
runTimeModifiable yes;

functions
{
    // Drag in the periodic channel: the meanVelocityForce in
    // constant/fvOptions logs the applied mean pressure gradient each
    // iteration (grep "Pressure gradient" log.simpleFoam). At matched
    // bulk velocity Ubar, DR% = (dpdx_smooth - dpdx_riblet)/dpdx_smooth.
    // wallShearStress is still emitted as an independent cross-check —
    // integral tau_w over the wetted walls must balance the body force.
    wallShearStress
    {
        type            wallShearStress;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   10;
        patches         ( bottomWall riblets );
        log             yes;
    }

    residuals
    {
        type            residuals;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields          ( U p k omega );
    }

    yPlus
    {
        type            yPlus;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        patches         ( bottomWall riblets );
    }
}
