FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}

simulationType  RAS;

RAS
{
    // Mele & Tognaccini 2022 MDPI Fluids 7(7):249 — RANS-riblet practice
    // paper benchmarks k-omega SST against Bechert blade-riblet data and
    // reproduces the DR curve shape. Garcia-Mayoral & Jimenez 2011 ARFM
    // 43:115-141 (canonical review) likewise uses SST or LES for DR work.
    RASModel        kOmegaSST;
    turbulence      on;
    printCoeffs     on;
}
