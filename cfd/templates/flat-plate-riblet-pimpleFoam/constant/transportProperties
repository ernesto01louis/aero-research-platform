FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}

transportModel  Newtonian;

// Streamwise-periodic channel, normalized on the half-height delta=1
// and friction velocity u_tau=1. The friction Reynolds number is
// Re_tau = u_tau * delta / nu, so nu = 1/Re_tau. At the canonical
// Re_tau = 180 (Kim, Moin & Moser 1987): nu = 1/180 = 5.5556e-3.
// Keep this consistent with --re-tau passed to scripts/generate_mesh.py.
nu              5.5556e-3;
