FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setExprFieldsDict;
}

// LES transition trip — streamwise-vortex initial condition.
//
// History: a pure rand() white-noise IC laminarised (energy at the
// grid scale, dissipates); coherent x-z rolls ALSO laminarised — but
// that second failure was the spanwise DOMAIN, not the IC: 4 riblet
// pitches is only 60-80 wall units wide, below the ~100 wall-unit
// minimal-channel threshold (Jimenez & Moin 1991), so turbulence
// cannot self-sustain regardless of the IC. The campaign now runs 8
// pitches (120-160 wall units).
//
// This IC superimposes x-uniform counter-rotating STREAMWISE VORTICES
// (the optimal transient-growth structure — Butler & Farrell 1992):
// the y-z-plane circulation lifts low-momentum fluid off the wall,
// generating streamwise streaks that break down into turbulence. u_y
// and u_z share the sin/cos(C3*y) structure so they form vortices;
// u_x is the streak. A smaller per-cell random component breaks the
// residual x-symmetry. sin(pi*z) envelopes vanish at the z=0 wall and
// z=1 symmetry plane. pi written numerically; C3 = 2*pi/0.56 sets a
// ~0.56-delta (~100 wall-unit) spanwise wavelength — the natural
// near-wall streak spacing.
//
// Applied by the run recipe:  setExprFields
expressions
(
    perturbU
    {
        field       U;
        // Amplitudes: streak 4.0, wall-normal 3.0, spanwise 2.0
        // (~13-25% of the 15.7 bulk), random +/-0.75.
        expression
        #{
            vector
            (
                15.7
                  + 4.0 * sin(3.14159265*pos().z()) * cos(11.22*pos().y())
                  + 1.5 * (rand() - 0.5),
                2.0 * cos(3.14159265*pos().z()) * sin(11.22*pos().y())
                  + 1.5 * (rand() - 0.5),
                3.0 * sin(3.14159265*pos().z()) * cos(11.22*pos().y())
                  + 1.5 * (rand() - 0.5)
            )
        #};
    }
);
