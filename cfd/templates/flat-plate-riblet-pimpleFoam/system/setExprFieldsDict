FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setExprFieldsDict;
}

// LES transition trip. A uniform (or purely random) field at
// Re_bulk ~= 2826 is sub-critical: white noise dissipates at the grid
// scale and the channel relaminarises (first pilot attempt settled to
// the laminar Poiseuille pressure gradient ~0.29 instead of the
// turbulent ~1.0). Transition needs a COHERENT finite-amplitude
// disturbance — counter-rotating streamwise rolls whose wall-normal
// velocity lifts low-momentum fluid off the wall (the lift-up
// mechanism) and seeds streaks that break down into turbulence.
//
// This superimposes x-z coherent rolls (streamwise + wall-normal +
// spanwise components, amplitude ~20-25% of bulk) plus a per-cell
// random component that breaks the residual 2-D symmetry into a 3-D
// field. sin(pi*z) envelopes vanish at the z=0 wall and z=1 symmetry
// plane so the BCs are not violated. pi is written numerically to
// avoid any dependence on the exprFields constant/function spelling.
//
// Applied by the run recipe:  setExprFields
expressions
(
    perturbU
    {
        field       U;
        // KX = 2*pi*2/Lx with Lx=3 -> two streamwise wavelengths.
        // Amplitudes: streamwise/spanwise roll 4.0, wall-normal 3.5
        // (~22% of the 15.7 bulk), random 3-D break-up +/-1.0.
        expression
        #{
            vector
            (
                15.7
                  + 4.0 * sin(3.14159265*pos().z()) * cos(4.18879020*pos().x())
                  + 2.0 * (rand() - 0.5),
                4.0 * sin(3.14159265*pos().z()) * cos(4.18879020*pos().x())
                  + 2.0 * (rand() - 0.5),
                3.5 * sin(3.14159265*pos().z()) * sin(4.18879020*pos().x())
                  + 2.0 * (rand() - 0.5)
            )
        #};
    }
);
