FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

ddtSchemes
{
    // 2nd-order implicit backward differencing — the standard LES time
    // scheme. CrankNicolson 0.9 is an alternative; backward is more
    // robust on the start-up transient from the random IC.
    default         backward;
}

gradSchemes
{
    // No limiter — LES needs the resolved gradients. The riblet groove
    // is well-resolved in the structured mesh; a cellLimited/cellMD
    // limiter (used for the RANS case) would clip the resolved
    // turbulent fluctuations.
    default         Gauss linear;
    grad(U)         Gauss linear;
}

divSchemes
{
    default         none;
    // Pure central differencing — zero numerical dissipation, the
    // canonical channel-LES convection scheme (OpenFOAM channel395
    // tutorial). LUST's 25% upwind component was tried first but adds
    // enough numerical dissipation to help drain a marginally-sustained
    // transitional flow back to laminar; central preserves the resolved
    // turbulent energy. If this rings on the graded core, fall back to
    // `Gauss LUST grad(U)`.
    div(phi,U)      Gauss linear;
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}
