[core]
    analytics = false
    remote = aero-minio
['remote "aero-minio"']
    url = s3://aero-dvc
    endpointurl = http://192.168.2.234:9000
# Stage 09 (ADR-011) — pluggable cloud-now / NAS-later remotes. The default
# stays aero-minio (small artifacts on LXC 212); large-dataset push/pull selects
# `-r aero-cloud` (now) or `-r aero-nas` (post-migration). Secret keys live in
# the gitignored .dvc/config.local + the boto3 env-var chain — never committed.
# aero-cloud (cloud-now): a RunPod network volume mounted into the H100 pod,
# used as a LOCAL DVC remote (no egress; data co-located with compute). Stage
# the ~600 GB DrivAerML subset to it once via a staging pod, then training pods
# `dvc pull -r aero-cloud` read it locally. The mount path is the pod-side
# volume mount point. ADR-011.
['remote "aero-cloud"']
    url = /runpod-volume/aero-dvc
['remote "aero-nas"']
    url = s3://aero-dvc
    endpointurl = http://192.168.2.100:9000
